{
  "runtime_root": "ordo-runtime",
  "bundled_repo_root": "repo",
  "bundled_python": {
    "root": "python",
    "executable": "python/bin/python3"
  },
  "bundled_node": {
    "root": "node",
    "executable": "node/bin/node"
  },
  "include": [
    "scripts/workbench_bridge.py",
    "scripts/format.py",
    "publish.py",
    "publish_console_state.py",
    "markdown_utils.py",
    "live_cdp.mjs",
    "live_cdp_ws_resolver.mjs",
    "zhihu_publisher.py",
    "toutiao_publisher.py",
    "yidian_publisher.py",
    "jianshu_publisher.py",
    "tiandi_engine",
    "themes",
    "templates"
  ],
  "exclude_globs": [
    "**/__pycache__/**",
    "**/*.pyc",
    "**/*.pyo",
    ".tiandidistribute/**",
    ".worktrees/**",
    ".cursor/**",
    ".superpowers/**",
    "docs/**",
    "tests/**",
    "desktop/**",
    "dist/**",
    "node_modules/**"
  ]
}
